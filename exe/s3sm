module S3SM
  module C
    # Colors
    RESET   = "\e[0m"
    BOLD    = "\e[1m"
    DIM     = "\e[2m"
    ITALIC  = "\e[3m"
    UNDER   = "\e[4m"

    BLACK   = "\e[30m"
    RED     = "\e[31m"
    GREEN   = "\e[32m"
    YELLOW  = "\e[33m"
    BLUE    = "\e[34m"
    MAGENTA = "\e[35m"
    CYAN    = "\e[36m"
    WHITE   = "\e[37m"

    BG_BLACK = "\e[40m"
    BG_RED   = "\e[41m"
    BG_GREEN = "\e[42m"
    BG_BLUE  = "\e[44m"
    BG_CYAN  = "\e[46m"

    def self.colorize(text, *codes)
      "#{codes.join}#{text}#{RESET}"
    end

    def self.bold(text)
      colorize(text, BOLD)
    end

    def self.dim(text)
      colorize(text, DIM)
    end

    def self.green(text)
      colorize(text, GREEN)
    end

    def self.red(text)
      colorize(text, RED)
    end

    def self.yellow(text)
      colorize(text, YELLOW)
    end

    def self.blue(text)
      colorize(text, BLUE)
    end

    def self.cyan(text)
      colorize(text, CYAN)
    end

    def self.magenta(text)
      colorize(text, MAGENTA)
    end

    def self.white(text)
      colorize(text, WHITE)
    end

    def self.white_bold(text)
      colorize(text, WHITE, BOLD)
    end

    def self.cyan_bold(text)
      colorize(text, CYAN, BOLD)
    end

    def self.green_bold(text)
      colorize(text, GREEN, BOLD)
    end

    def self.yellow_bold(text)
      colorize(text, YELLOW, BOLD)
    end

    def self.red_bold(text)
      colorize(text, RED, BOLD)
    end

    def self.magenta_bold(text)
      colorize(text, MAGENTA, BOLD)
    end

    def self.blue_bold(text)
      colorize(text, BLUE, BOLD)
    end
  end

  S3_FRIENDLY_MESSAGES = {
    "NoSuchBucket" => ->(b) { "Bucket #{C.bold(b)} does not exist. Create it first or check the bucket name." },
    "AccessDenied" => ->(b) { "Access denied to #{C.bold(b)}. Check your credentials and bucket permissions." },
    "SignatureDoesNotMatch" => ->(_b) { "Request signature mismatch. Check your access key and secret key." },
    "InvalidAccessKeyId" => ->(_b) { "Invalid access key. Verify your AWS_ACCESS_KEY_ID." },
    "ExpiredToken" => ->(_b) { "Security token has expired. Refresh your credentials." },
    "BucketAlreadyOwnedByYou" => ->(b) { "Bucket #{C.bold(b)} already exists and is owned by you." },
    "BucketAlreadyExists" => ->(b) { "Bucket #{C.bold(b)} already exists. Choose a different name." }
  }.freeze

  module Formatters
    def format_size(bytes)
      return "0 B" if bytes.nil? || bytes.zero?

      units = %w[B KB MB GB TB]
      size = bytes.to_f
      units.each_with_index do |unit, i|
        return format("%.1f %s", size, unit) if size < 1024 || i == units.length - 1

        size /= 1024
      end
    end

    def format_s3_error_from_exception(error)
      s3_code    = error.s3_code
      s3_message = error.s3_message
      bucket     = error.s3_bucket

      header = "#{C.red_bold('✗')} S3 error"
      header += " (#{C.red(s3_code)})" if s3_code
      header += " [HTTP #{error.code}]" unless s3_code

      if s3_code && S3_FRIENDLY_MESSAGES.key?(s3_code)
        detail = S3_FRIENDLY_MESSAGES[s3_code].call(bucket)
      else
        parts = []
        parts << s3_message if s3_message && s3_message != s3_code
        parts << "bucket: #{C.bold(bucket)}" if bucket
        detail = parts.empty? ? clean_error_message(error) : parts.join(" — ")
      end

      "#{header}\n  #{detail}"
    end

    def clean_error_message(error)
      msg = error.message.to_s
      msg.sub(/^\[S3 \d+\]\s*/, "").sub(/\s*\(req=[^)]+\)/, "").strip
    end
  end

  module Commands
    class Upload
      extend Formatters

      def self.call(client, args)
        opts = parse_opts(args)
        abort "#{C.red_bold('✗')} Usage: s3sm upload <local_path> [--key KEY] [--bucket BUCKET]" unless opts[:local_path]

        path = opts[:local_path]
        key  = opts[:key] || File.basename(path)
        opts[:key] = key
        size = File.exist?(path) ? format_size(File.size(path)) : nil

        $stdout.print "#{C.dim('⬆  Uploading')} #{C.bold(File.basename(path))}"
        $stdout.print " #{C.dim("(#{size})")}" if size
        $stdout.print " #{C.dim('→')} #{C.cyan_bold(key)}"
        $stdout.print " #{C.dim('in')} #{C.magenta_bold(opts[:bucket] || 'default')}" if opts[:bucket]
        $stdout.puts

        result = client.upload_file(**opts.except(:file_path))
        puts "  #{C.green_bold('✓')} #{C.green('Uploaded')} #{C.bold(result.key)}"
      rescue S3BaseClient::UploadError => e
        abort "#{C.red_bold('✗')} #{e.message}"
      end

      def self.parse_opts(args)
        opts = { local_path: nil, file_path: nil, key: nil, bucket: nil,
                 content_type: "application/octet-stream", metadata: {},
                 cache_control: nil, skip_existing: false,
                 concurrency: nil, retries: nil }
        OptionParser.new do |o|
          o.banner = "#{C.bold('Usage:')} s3sm upload <local_path> [options]"
          o.on("--key KEY", "S3 object key (default: filename)") { |v| opts[:key] = v }
          o.on("--bucket BUCKET", "Bucket name (default: ENV['AWS_BUCKET'] or global)") { |v| opts[:bucket] = v }
          o.on("--content-type TYPE", "Content-Type header") { |v| opts[:content_type] = v }
          o.on("--skip-existing", "Skip if object already exists") { opts[:skip_existing] = true }
          o.on("--concurrency N", Integer, "Max concurrent threads") { |v| opts[:concurrency] = v }
          o.on("--retries N", Integer, "Max retries per part") { |v| opts[:retries] = v }
          o.on("--cache-control VAL", "Cache-Control header") { |v| opts[:cache_control] = v }
        end.parse!(args)

        path = args.shift
        if path
          opts[:local_path] = path
          opts[:file_path]  = path
        end
        opts[:bucket] ||= ENV.fetch("AWS_BUCKET", nil)
        opts[:metadata] = {} if opts[:metadata].nil?
        opts.compact
      end
    end

    class Download
      def self.call(client, args)
        opts = parse_opts(args)
        abort "#{C.red_bold('✗')} Usage: s3sm download <key> [local_path] --bucket BUCKET" unless opts[:key]

        $stdout.puts "#{C.dim('⬇  Downloading')} #{C.cyan_bold(opts[:key])} #{C.dim('→')} #{C.bold(opts[:destination_path] || '.')}"
        result = client.download_file(**opts)
        puts "  #{C.green_bold('✓')} #{C.green('Downloaded to')} #{C.bold(result.local_path)}"
      rescue S3BaseClient::DownloadError => e
        abort "#{C.red_bold('✗')} #{e.message}"
      end

      def self.parse_opts(args)
        opts = { key: nil, bucket: nil, destination_path: nil, local_path: nil, resume: false }
        OptionParser.new do |o|
          o.banner = "#{C.bold('Usage:')} s3sm download <key> [local_path] [options]"
          o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
          o.on("--resume", "Resume previous download") { opts[:resume] = true }
        end.parse!(args)

        opts[:key] = args.shift
        if (dest = args.shift)
          opts[:destination_path] = dest
          opts[:local_path]       = dest
        end
        opts.compact
      end
    end

    class Presign
      def self.call(client, args)
        opts = parse_opts(args)
        abort "#{C.red_bold('✗')} Usage: s3sm presign <key> [--bucket BUCKET]" unless opts[:key]

        url = client.presigned_url(**opts)
        puts "#{C.dim('🔗')} #{C.under}#{url}#{C::RESET}"
        puts ""
        puts "#{C.dim('Expires in')} #{C.yellow_bold(opts[:expires_in])} #{C.dim('seconds')}"
      end

      def self.parse_opts(args)
        opts = { key: nil, bucket: nil, expires_in: 3600, method: :get }
        OptionParser.new do |o|
          o.banner = "#{C.bold('Usage:')} s3sm presign <key> [options]"
          o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
          o.on("--expires SECONDS", Integer, "Expiration in seconds (default: 3600)") { |v| opts[:expires_in] = v }
          o.on("--method METHOD", %w[get put delete head], "HTTP method (get/put/delete/head)") { |v| opts[:method] = v.to_sym }
        end.parse!(args)

        opts[:key] = args.shift
