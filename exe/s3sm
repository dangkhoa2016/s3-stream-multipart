    class UploadDir
      extend Formatters

      def self.call(client, args, error_formatter: nil)
        opts = parse_opts(args)
        abort "#{C.red_bold('✗')} Usage: s3sm upload-dir <directory> [--bucket BUCKET]" unless opts[:directory]

        skip_label = opts[:skip_existing] ? "skip-existing" : "overwrite"
        resume_label = opts[:resume] ? "resume" : "no-resume"
        $stdout.puts "#{C.dim('📂 Uploading directory')} #{C.bold(opts[:directory])} #{C.dim('→')} #{C.magenta_bold(opts[:bucket] || 'default')}"
        $stdout.puts "#{C.dim('   Mode:')} #{C.cyan(skip_label)}, #{C.cyan(resume_label)}"

        result = client.upload_directory(**opts, on_file_start: build_on_start, on_file_complete: build_on_complete)

        print_summary(result, opts[:directory])
      rescue S3Errors::S3Error => e
        abort error_formatter&.call(e) || e.message
      rescue Errno::ENOENT => e
        abort "#{C.red_bold('✗')} #{e.message}"
      end

      def self.parse_opts(args)
        opts = { directory: nil, bucket: nil, prefix: "", pattern: "**/*",
                 exclude: [], max_files: 4, skip_existing: true, resume: true }
        OptionParser.new do |o|
          o.banner = "#{C.bold('Usage:')} s3sm upload-dir <directory> [options]"
          o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
          o.on("--prefix PREFIX", "Key prefix for uploaded files") { |v| opts[:prefix] = v }
          o.on("--pattern PAT", "File glob pattern (default: **/*)") { |v| opts[:pattern] = v }
          o.on("--max-files N", Integer, "Max concurrent file uploads") { |v| opts[:max_files] = v }
          o.on("--no-skip-existing", "Upload even if file already exists with matching size/etag") { opts[:skip_existing] = false }
          o.on("--resume", "Resume interrupted multipart uploads from state files") { opts[:resume] = true }
          o.on("--state-dir DIR", "Directory for per-file resume state (default: /tmp/s3sm-state)") do |v|
            opts[:state_dir] = v
          end
        end.parse!(args)

        opts[:directory] = args.shift
        opts[:bucket] ||= ENV.fetch("AWS_BUCKET", nil)
        opts[:state_dir] ||= "/tmp/s3sm-state" if opts[:resume]
        opts.compact
      end

      def self.build_on_start
        lambda do |path, key, idx, total|
          name = File.basename(path)
          $stdout.puts "  #{C.dim('⬆')} [#{C.cyan_bold("#{idx}/#{total}")}] #{C.bold(name)} #{C.dim('→')} #{C.cyan(key)}"
        end
      end

      def self.build_on_complete
        lambda do |path, _key, result, idx, total|
          size = result.is_a?(Hash) ? result[:size] : nil
          elapsed = result.is_a?(Hash) ? result[:elapsed] : nil
          info = []
          info << C.dim(format_size(size)) if size
          info << C.dim("#{format('%.2f', elapsed)}s") if elapsed
          suffix = info.empty? ? "" : " (#{info.join(', ')})"
          $stdout.puts "  #{C.green_bold('✓')} [#{C.cyan_bold("#{idx}/#{total}")}] #{C.green(File.basename(path))}#{suffix}"
        end
      end

      def self.print_summary(result, directory)
        uploaded_count = result[:uploaded].size
        failed_count   = result[:failed].size
        skipped_count  = result[:skipped].size

        $stdout.puts ""
        if uploaded_count.positive?
          puts "  #{C.green_bold('✓')} #{C.green('Uploaded')} #{C.green_bold(uploaded_count.to_s)} " \
               "#{uploaded_count == 1 ? 'file' : 'files'} from #{C.bold(directory)}"
        end
        if failed_count.positive?
          puts "  #{C.red_bold('✗')} #{C.red('Failed')} #{C.red_bold(failed_count.to_s)} " \
               "#{failed_count == 1 ? 'file' : 'files'}"
          result[:failed].each do |f|
            puts "    #{C.red('•')} #{f[:key]}: #{C.dim(f[:error])}"
          end
        end
        return unless skipped_count.positive?

        puts "  #{C.yellow_bold('⊘')} #{C.yellow('Skipped')} #{C.yellow_bold(skipped_count.to_s)} " \
             "#{skipped_count == 1 ? 'file' : 'files'}"
      end
      private_class_method :build_on_start, :build_on_complete, :print_summary
    end

    class DownloadDir
      def self.call(client, args, error_formatter: nil)
        opts = parse_opts(args)
        abort "#{C.red_bold('✗')} Usage: s3sm download-dir <local_directory> [--prefix PREFIX] [--bucket BUCKET]" unless opts[:local_directory]

        $stdout.puts "#{C.dim('📂 Downloading from')} #{C.cyan_bold(opts[:prefix] || '/')} #{C.dim('→')} #{C.bold(opts[:local_directory])}"
        result = client.download_directory(**opts)

        print_summary(result, opts[:local_directory])
      rescue S3Errors::S3Error => e
        abort error_formatter&.call(e) || e.message
      rescue Errno::ENOENT => e
        abort "#{C.red_bold('✗')} #{e.message}"
      end

      def self.parse_opts(args)
        opts = { local_directory: nil, prefix: "", delimiter: nil,
                 exclude: [], max_files: 4 }
        OptionParser.new do |o|
          o.banner = "#{C.bold('Usage:')} s3sm download-dir <local_directory> [options]"
          o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
          o.on("--prefix PREFIX", "Key prefix to filter objects") { |v| opts[:prefix] = v }
          o.on("--delimiter DELIM", "Delimiter for listing (default: auto)") { |v| opts[:delimiter] = v }
          o.on("--max-files N", Integer, "Max concurrent file downloads") { |v| opts[:max_files] = v }
        end.parse!(args)

        opts[:local_directory] = args.shift
        opts[:bucket] ||= ENV.fetch("AWS_BUCKET", nil)
        opts.compact
      end

      def self.print_summary(result, local_directory)
        downloaded_count = result[:downloaded].size
        failed_count     = result[:failed].size

        if downloaded_count.positive?
          puts "  #{C.green_bold('✓')} #{C.green('Downloaded')} #{C.green_bold(downloaded_count.to_s)} " \
               "#{downloaded_count == 1 ? 'file' : 'files'} to #{C.bold(local_directory)}"
        end
        return unless failed_count.positive?

        puts "  #{C.red_bold('✗')} #{C.red('Failed')} #{C.red_bold(failed_count.to_s)} " \
             "#{failed_count == 1 ? 'file' : 'files'}"
        result[:failed].each do |f|
          puts "    #{C.red('•')} #{f[:key]}: #{C.dim(f[:error])}"
        end
      end
      private_class_method :print_summary
    end
  end

  class CLI
    include Formatters

    COMMANDS = %w[upload download presign delete list list-parts list-uploads upload-dir download-dir].freeze

    # Global options that take a value argument
    GLOBAL_OPTS_WITH_VALUE = %w[
      --endpoint --region --access-key --secret-key
      --endpoint-style --signature-version
    ].freeze

    # Boolean global options (no value argument)
    GLOBAL_OPTS_BOOLEAN = %w[--debug --help].freeze

    def run(args)
      global, command, command_args = parse(args)
      return print_help if global[:help]

      client = build_client(global)
      dispatch(command, client, command_args)
    rescue KeyError
      abort "#{C.red_bold('✗')} Unknown command: #{C.bold(command)}. Run #{C.cyan('s3sm --help')} for usage."
    rescue OptionParser::MissingArgument, OptionParser::InvalidOption => e
      abort "#{C.red_bold('✗')} #{e.message}"
    rescue S3Errors::S3Error => e
      abort format_s3_error_from_exception(e)
    rescue StandardError => e
      abort "#{C.red_bold('✗')} #{e.class}: #{e.message}"
    end

    COMMAND_MAP = {
      "upload" => Commands::Upload,
      "download" => Commands::Download,
      "presign" => Commands::Presign,
      "delete" => Commands::Delete,
      "list" => Commands::List,
      "list-parts" => Commands::ListParts,
      "list-uploads" => Commands::ListUploads,
      "upload-dir" => Commands::UploadDir,
      "download-dir" => Commands::DownloadDir
    }.freeze

    private

    def dispatch(command, client, args)
      cmd_class = COMMAND_MAP.fetch(command)
      if [Commands::UploadDir, Commands::DownloadDir].include?(cmd_class)
        cmd_class.call(client, args, error_formatter: method(:format_s3_error_from_exception))
      else
        cmd_class.call(client, args)
      end
    end

    def parse(args)
      global = {}
      opts = OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm [options] <command> [command-options]"
        o.separator ""
        o.separator C.bold(C.cyan("Global options:")).to_s
        o.on("--endpoint URL", "S3-compatible endpoint (e.g., https://minio.local:9000)") { |v| global[:endpoint] = v }
        o.on("--region REGION", "AWS region (default: us-east-1)") { |v| global[:region] = v }
        o.on("--bucket BUCKET", "Default bucket name") { |v| global[:bucket] = v }
        o.on("--access-key KEY", "Access key ID (env: AWS_ACCESS_KEY_ID)") { |v| global[:'access-key'] = v }
        o.on("--secret-key KEY", "Secret access key (env: AWS_SECRET_ACCESS_KEY)") { |v| global[:'secret-key'] = v }
        o.on("--endpoint-style STYLE", %w[path virtual-hosted],
             "Endpoint style: path or virtual-hosted (env: AWS_ENDPOINT_STYLE)") { |v| global[:'endpoint-style'] = v }
        o.on("--signature-version VERSION", %w[v2 v4],
             "SigV2 or SigV4 signing (default: v4, env: AWS_SIGNATURE_VERSION)") { |v| global[:'signature-version'] = v }
        o.on("--debug", "Enable debug logging") { global[:debug] = true }
        o.separator ""
        o.separator C.bold(C.magenta("Commands:")).to_s
        o.separator "    #{C.green_bold('upload')}      Upload a file"
        o.separator "    #{C.green_bold('download')}    Download a file"
        o.separator "    #{C.green_bold('presign')}     Generate a presigned URL"
        o.separator "    #{C.green_bold('delete')}      Delete an object"
        o.separator "    #{C.green_bold('list')}         List objects in a bucket"
        o.separator "    #{C.green_bold('list-parts')}  List parts of a multipart upload"
        o.separator "    #{C.green_bold('list-uploads')} List active multipart uploads"
        o.separator "    #{C.green_bold('upload-dir')}  Upload a directory"
        o.separator "    #{C.green_bold('download-dir')} Download a directory"
        o.separator ""
        o.on("-h", "--help", "Show this help") { global[:help] = true }
      end

      cmd_idx = args.index { |a| COMMANDS.include?(a) }

      if cmd_idx
        pre_args  = args[0...cmd_idx]
        command   = args[cmd_idx]
        post_args = args[(cmd_idx + 1)..]
      else
        pre_args  = args.dup
        command   = nil
        post_args = []
      end

      opts.order!(pre_args)

      extracted, post_args = extract_global_from_args(post_args)
      opts.order!(extracted)

      global[:help] ||= command.nil? && pre_args.empty? && post_args.empty?
      [global, command, post_args]
    end

    def extract_global_from_args(args)
      global = []
      rest = []
      i = 0
      while i < args.length
        if GLOBAL_OPTS_WITH_VALUE.include?(args[i])
          global << args[i]
          if i + 1 < args.length
            global << args[i + 1]
            i += 2
          else
            i += 1
          end
        elsif GLOBAL_OPTS_BOOLEAN.include?(args[i])
          global << args[i]
          i += 1
        else
          rest << args[i]
          i += 1
        end
      end
      [global, rest]
    end

    def build_client(global)
      region  = global[:region]  || ENV.fetch("AWS_REGION", "us-east-1")
      bucket  = global[:bucket]  || ENV.fetch("AWS_BUCKET", nil)
      bucket = nil if bucket.to_s.strip.empty?
      endpoint = global[:endpoint] || ENV.fetch("AWS_ENDPOINT", nil)
      endpoint = "https://#{endpoint}" if endpoint && !endpoint.start_with?("http://", "https://")
      ak      = global[:'access-key'] || ENV.fetch("AWS_ACCESS_KEY_ID", nil)
      sk      = global[:'secret-key'] || ENV.fetch("AWS_SECRET_ACCESS_KEY", nil)
      endpoint_style = (global[:'endpoint-style'] || ENV.fetch("AWS_ENDPOINT_STYLE", nil))&.to_sym
      signature_version = (global[:'signature-version'] || ENV.fetch("AWS_SIGNATURE_VERSION", nil))&.to_sym || :v4

      if endpoint
        S3MultiBucketClient.new(
          region: region, bucket: bucket, endpoint: endpoint,
          access_key_id: ak, secret_access_key: sk,
          debug: global[:debug],
          signature_version: signature_version,
          **(endpoint_style ? { endpoint_style: endpoint_style } : {})
        )
      else
        S3Client.new(region: region, bucket: bucket,
                     access_key_id: ak, secret_access_key: sk,
                     debug: global[:debug],
                     signature_version: signature_version)
      end
    rescue KeyError => e
      abort "#{C.red_bold('✗')} Missing required credential: #{e.message}"
    end

    def print_help
      puts ""
      puts "  #{C.bold(C.cyan('s3sm'))} #{C.dim('—')} #{C.bold('S3 Stream Multipart CLI')}"
      puts "  #{C.dim('─' * 50)}"
      puts ""
      puts "  #{C.bold(C.white('Usage:'))} s3sm [global-options] <command> [command-options]"
      puts ""
      puts "  #{C.bold(C.cyan('Global options:'))}"
      puts "      #{C.green('--endpoint')} URL            S3-compatible endpoint URL"
      puts "      #{C.green('--region')} REGION           AWS region (default: us-east-1, env: AWS_REGION)"
      puts "      #{C.green('--bucket')} BUCKET           Default bucket (env: AWS_BUCKET)"
      puts "      #{C.green('--access-key')} KEY          Access key ID (env: AWS_ACCESS_KEY_ID)"
      puts "      #{C.green('--secret-key')} KEY          Secret access key (env: AWS_SECRET_ACCESS_KEY)"
      puts "      #{C.green('--endpoint-style')} STYLE    Path or virtual-hosted (env: AWS_ENDPOINT_STYLE)"
      puts "      #{C.green('--signature-version')} VER   SigV2 or SigV4 (default: v4, env: AWS_SIGNATURE_VERSION)"
      puts "      #{C.green('--debug')}                  Enable debug logging"
      puts "      #{C.green('-h, --help')}               Show this help"
      puts ""
      puts "  #{C.bold(C.magenta('Commands:'))}"
      puts "      #{C.green_bold('list')}                    List objects in a bucket"
      puts "      #{C.green_bold('upload')} <path> --key KEY  Upload a file"
      puts "      #{C.green_bold('download')} <key> [dest]    Download a file"
      puts "      #{C.green_bold('presign')} <key>            Generate presigned URL"
      puts "      #{C.green_bold('delete')} <key>             Delete an object"
      puts "      #{C.green_bold('list-parts')} <key>         List multipart upload parts"
      puts "      #{C.green_bold('list-uploads')}             List active multipart uploads"
      puts "      #{C.green_bold('upload-dir')} <directory>   Upload a directory"
      puts "      #{C.green_bold('download-dir')} <local_dir>  Download a directory"
      puts ""
      puts "  #{C.dim('Run:')} #{C.cyan('s3sm <command> --help')} #{C.dim('for command-specific options.')}"
      puts "  #{C.dim('Environment:')} #{C.yellow('AWS_ACCESS_KEY_ID')}, #{C.yellow('AWS_SECRET_ACCESS_KEY')}, #{C.yellow('AWS_REGION')},"
      puts "                   #{C.yellow('AWS_BUCKET')}, #{C.yellow('AWS_ENDPOINT')}, #{C.yellow('AWS_SIGNATURE_VERSION')}."
      puts ""
    end
  end
end

S3SM::CLI.new.run(ARGV)
