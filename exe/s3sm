    class List
      extend Formatters

      def self.call(client, args)
        opts = parse_opts(args)
        opts[:bucket] ||= client.bucket

        if opts[:bucket]
          list_objects_in_bucket(client, opts)
        elsif client.respond_to?(:list_buckets)
          puts "  #{C.dim('ℹ')} #{C.dim('No bucket specified — listing all buckets.')}"
          list_all_buckets(client, opts)
        else
          abort "#{C.red_bold('✗')} No bucket specified. Use --bucket or set AWS_BUCKET."
        end
      end

      def self.list_objects_in_bucket(client, opts)
        result = client.list_objects(**opts)
        contents = result[:contents]
        common_prefixes = result[:common_prefixes]

        bucket_label = C.magenta_bold(opts[:bucket] || "default")
        prefix_label = opts[:prefix] ? " #{C.dim('(prefix:')} #{C.cyan(opts[:prefix])}#{C.dim(')')}" : ""

        puts ""
        puts "  #{C.bold('📦')} #{C.bold('Objects in')} #{bucket_label}#{prefix_label}"
        puts "  #{C.dim('─' * 78)}"

        if contents.empty? && common_prefixes.empty?
          puts "  #{C.dim('(empty)')}"
          puts ""
          return
        end

        unless contents.empty?
          header = "  #{C.bold(C.white('Key'))}  #{C.bold(C.white('Size'))}  " \
                   "#{C.bold(C.white('Last Modified'))}  #{C.bold(C.white('Class'))}  #{C.bold(C.white('ETag'))}"
          puts header
          puts "  #{C.dim('─' * 78)}"

          contents.each do |obj|
            size_str = obj[:size] ? format_size(obj[:size]) : "—"
            key_display = obj[:key].to_s
            key_display = "#{C.dim('…')}#{key_display[-57..]}" if key_display.length > 60
            key_display = C.green_bold(key_display)

            size_padded = size_str.rjust(10)
            size_display = case obj[:size]
                           when nil..0         then C.dim(size_padded)
                           when 1..(1024**2)   then C.green(size_padded)
                           when (1024**2)..(1024**3) then C.yellow(size_padded)
                           else C.red_bold(size_padded)
                           end

            puts "  #{key_display}  #{size_display}  #{C.dim(obj[:last_modified])}  #{C.cyan(obj[:storage_class])}  #{C.dim(obj[:etag])}"
          end
        end

        if common_prefixes.any?
          puts ""
          puts "  #{C.bold('📁')} #{C.bold('Common prefixes:')}"
          common_prefixes.each { |p| puts "  #{C.blue_bold(p)}" }
        end

        total_size = contents.sum { |o| o[:size] || 0 }
        puts ""
        puts "  #{C.dim('─' * 78)}"
        puts "  #{C.bold('Total:')} #{C.green_bold(contents.size.to_s)} #{contents.size == 1 ? 'object' : 'objects'}, #{C.yellow_bold(format_size(total_size))}"
        puts ""
      end

      def self.list_all_buckets(client, _opts)
        buckets = client.list_buckets

        puts ""
        puts "  #{C.bold('📦')} #{C.bold('Buckets')}"
        puts "  #{C.dim('─' * 78)}"

        if buckets.empty?
          puts "  #{C.dim('(no buckets)')}"
          puts ""
          return
        end

        buckets.each do |bucket_info|
          name = bucket_info[:name]
          created = bucket_info[:creation_date] ? "  #{C.dim(bucket_info[:creation_date])}" : ""
          puts "  #{C.magenta_bold(name)}#{created}"
        end

        puts ""
        puts "  #{C.dim('─' * 78)}"
        puts "  #{C.bold('Total:')} #{C.green_bold(buckets.size.to_s)} #{buckets.size == 1 ? 'bucket' : 'buckets'}"
        puts ""
      end

      def self.parse_opts(args)
        opts = { bucket: nil, prefix: nil, delimiter: "/", max_keys: 100, paginate: true, recursive: false }
        delimiter_set = false
        OptionParser.new do |o|
          o.banner = "#{C.bold('Usage:')} s3sm list [options]"
          o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
          o.on("--prefix PREFIX", "Filter by key prefix") { |v| opts[:prefix] = v }
          o.on("--delimiter DELIM", "Delimiter (default: /, ignored if --recursive)") do |v|
            opts[:delimiter] = v
            delimiter_set = true
          end
          o.on("--recursive", "List all objects recursively (sets delimiter=\"\")") { opts[:recursive] = true }
          o.on("--max-keys N", Integer, "Max keys to list (default: 1000)") { |v| opts[:max_keys] = v }
          o.on("--no-paginate", "Disable auto-pagination") { opts[:paginate] = false }
        end.parse!(args)

        if opts[:recursive] && delimiter_set
          warn "#{C.yellow_bold('⚠')} Both --recursive and --delimiter specified: --delimiter takes precedence, --recursive ignored."
        elsif opts[:recursive]
          opts[:delimiter] = ""
        end

        opts.delete(:recursive)
        opts.compact
      end
    end

    class ListParts
      extend Formatters

      def self.call(client, args)
        opts = parse_opts(args)
        abort "#{C.red_bold('✗')} Usage: s3sm list-parts <key> --upload-id ID [--bucket BUCKET]" unless opts[:key] && opts[:upload_id]

        result = client.list_parts(**opts)
        parts = result[:parts] || []

        puts ""
        puts "  #{C.bold('🔩')} #{C.bold('Parts for')} #{C.cyan_bold(opts[:key])}"
        puts "  #{C.dim('Upload:')} #{C.yellow(opts[:upload_id])}"
        puts "  #{C.dim('─' * 60)}"

        if parts.empty?
          puts "  #{C.dim('(no parts)')}"
        else
          puts "  #{C.bold(C.white('Part'))}  #{C.bold(C.white('ETag'))}  #{C.bold(C.white('Size'))}"
          puts "  #{C.dim('─' * 60)}"
          parts.each do |p|
            puts "  #{C.magenta_bold("Part #{p[:part_number]}").ljust(12)} #{C.dim(p[:etag])}  #{C.green(format_size(p[:size]))}"
          end
        end
        puts ""
      end

      def self.parse_opts(args)
        opts = { key: nil, upload_id: nil, bucket: nil, max_parts: 100 }
        OptionParser.new do |o|
          o.banner = "#{C.bold('Usage:')} s3sm list-parts <key> --upload-id ID [options]"
          o.on("--upload-id ID", "Upload ID (required)") { |v| opts[:upload_id] = v }
          o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
          o.on("--max-parts N", Integer, "Max parts to list") { |v| opts[:max_parts] = v }
        end.parse!(args)

        opts[:key] = args.shift
