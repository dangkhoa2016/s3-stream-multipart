#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require_relative "../src/s3_client"
require_relative "../src/s3_multi_bucket_client"

module S3SM
  module C
    # Colors
    RESET   = "\e[0m"
    BOLD    = "\e[1m"
    DIM     = "\e[2m"
    ITALIC  = "\e[3m"
    UNDER   = "\e[4m"

    BLACK   = "\e[30m"
    RED     = "\e[31m"
    GREEN   = "\e[32m"
    YELLOW  = "\e[33m"
    BLUE    = "\e[34m"
    MAGENTA = "\e[35m"
    CYAN    = "\e[36m"
    WHITE   = "\e[37m"

    BG_BLACK = "\e[40m"
    BG_RED   = "\e[41m"
    BG_GREEN = "\e[42m"
    BG_BLUE  = "\e[44m"
    BG_CYAN  = "\e[46m"

    def self.colorize(text, *codes)
      "#{codes.join}#{text}#{RESET}"
    end

    def self.bold(text)
      colorize(text, BOLD)
    end

    def self.dim(text)
      colorize(text, DIM)
    end

    def self.green(text)
      colorize(text, GREEN)
    end

    def self.red(text)
      colorize(text, RED)
    end

    def self.yellow(text)
      colorize(text, YELLOW)
    end

    def self.blue(text)
      colorize(text, BLUE)
    end

    def self.cyan(text)
      colorize(text, CYAN)
    end

    def self.magenta(text)
      colorize(text, MAGENTA)
    end

    def self.white(text)
      colorize(text, WHITE)
    end

    def self.white_bold(text)
      colorize(text, WHITE, BOLD)
    end

    def self.cyan_bold(text)
      colorize(text, CYAN, BOLD)
    end

    def self.green_bold(text)
      colorize(text, GREEN, BOLD)
    end

    def self.yellow_bold(text)
      colorize(text, YELLOW, BOLD)
    end

    def self.red_bold(text)
      colorize(text, RED, BOLD)
    end

    def self.magenta_bold(text)
      colorize(text, MAGENTA, BOLD)
    end

    def self.blue_bold(text)
      colorize(text, BLUE, BOLD)
    end
  end

  S3_FRIENDLY_MESSAGES = {
    "NoSuchBucket" => ->(b) { "Bucket #{C.bold(b)} does not exist. Create it first or check the bucket name." },
    "AccessDenied" => ->(b) { "Access denied to #{C.bold(b)}. Check your credentials and bucket permissions." },
    "SignatureDoesNotMatch" => ->(_b) { "Request signature mismatch. Check your access key and secret key." },
    "InvalidAccessKeyId" => ->(_b) { "Invalid access key. Verify your AWS_ACCESS_KEY_ID." },
    "ExpiredToken" => ->(_b) { "Security token has expired. Refresh your credentials." },
    "BucketAlreadyOwnedByYou" => ->(b) { "Bucket #{C.bold(b)} already exists and is owned by you." },
    "BucketAlreadyExists" => ->(b) { "Bucket #{C.bold(b)} already exists. Choose a different name." }
  }.freeze

  module Formatters
    def format_size(bytes)
      return "0 B" if bytes.nil? || bytes.zero?

      units = %w[B KB MB GB TB]
      size = bytes.to_f
      units.each_with_index do |unit, i|
        return format("%.1f %s", size, unit) if size < 1024 || i == units.length - 1

        size /= 1024
      end
    end

    def format_s3_error_from_exception(error)
      s3_code    = error.s3_code
      s3_message = error.s3_message
      bucket     = error.s3_bucket

      header = "#{C.red_bold('✗')} S3 error"
      header += " (#{C.red(s3_code)})" if s3_code
      header += " [HTTP #{error.code}]" unless s3_code

      if s3_code && S3_FRIENDLY_MESSAGES.key?(s3_code)
        detail = S3_FRIENDLY_MESSAGES[s3_code].call(bucket)
      else
        parts = []
        parts << s3_message if s3_message && s3_message != s3_code
        parts << "bucket: #{C.bold(bucket)}" if bucket
        detail = parts.empty? ? clean_error_message(error) : parts.join(" — ")
      end

      "#{header}\n  #{detail}"
    end

    def clean_error_message(error)
      msg = error.message.to_s
      msg.sub(/^\[S3 \d+\]\s*/, "").sub(/\s*\(req=[^)]+\)/, "").strip
    end
  end

  class CLI
    include Formatters

    COMMANDS = %w[upload download presign delete list list-parts list-uploads upload-dir].freeze

    def run(args)
      global, command, command_args = parse(args)
      return print_help if global[:help]

      client = build_client(global)
      send("cmd_#{command.tr('-', '_')}", client, command_args)
    rescue KeyError
      abort "#{C.red_bold('✗')} Unknown command: #{C.bold(command)}. Run #{C.cyan('s3sm --help')} for usage."
    rescue OptionParser::MissingArgument, OptionParser::InvalidOption => e
      abort "#{C.red_bold('✗')} #{e.message}"
    rescue S3Errors::S3Error => e
      abort format_s3_error_from_exception(e)
    rescue StandardError => e
      abort "#{C.red_bold('✗')} #{e.class}: #{e.message}"
    end

    private

    def parse(args)
      global = {}
      opts = OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm [options] <command> [command-options]"
        o.separator ""
        o.separator C.bold(C.cyan("Global options:")).to_s
        o.on("--endpoint URL", "S3-compatible endpoint (e.g., https://minio.local:9000)") { |v| global[:endpoint] = v }
        o.on("--region REGION", "AWS region (default: us-east-1)") { |v| global[:region] = v }
        o.on("--bucket BUCKET", "Default bucket name") { |v| global[:bucket] = v }
        o.on("--access-key KEY", "Access key ID (env: AWS_ACCESS_KEY_ID)") { |v| global[:'access-key'] = v }
        o.on("--secret-key KEY", "Secret access key (env: AWS_SECRET_ACCESS_KEY)") { |v| global[:'secret-key'] = v }
        o.on("--endpoint-style STYLE", %w[path virtual-hosted],
             "Endpoint style: path or virtual-hosted (env: AWS_ENDPOINT_STYLE)") { |v| global[:'endpoint-style'] = v }
        o.on("--signature-version VERSION", %w[v2 v4],
             "SigV2 or SigV4 signing (default: v4, env: AWS_SIGNATURE_VERSION)") { |v| global[:'signature-version'] = v }
        o.on("--debug", "Enable debug logging") { global[:debug] = true }
        o.separator ""
        o.separator C.bold(C.magenta("Commands:")).to_s
        o.separator "    #{C.green_bold('upload')}      Upload a file"
        o.separator "    #{C.green_bold('download')}    Download a file"
        o.separator "    #{C.green_bold('presign')}     Generate a presigned URL"
        o.separator "    #{C.green_bold('delete')}      Delete an object"
        o.separator "    #{C.green_bold('list')}         List objects in a bucket"
        o.separator "    #{C.green_bold('list-parts')}  List parts of a multipart upload"
        o.separator "    #{C.green_bold('list-uploads')} List active multipart uploads"
        o.separator "    #{C.green_bold('upload-dir')}  Upload a directory"
        o.separator ""
        o.on("-h", "--help", "Show this help") { global[:help] = true }
      end
      rest = opts.permute!(args)
      global[:help] ||= rest.empty?
      command = rest.shift
      [global, command, rest]
    end

    def build_client(global)
      region  = global[:region]  || ENV.fetch("AWS_REGION", "us-east-1")
      bucket  = global[:bucket]  || ENV.fetch("AWS_BUCKET", nil)
      endpoint = global[:endpoint] || ENV.fetch("AWS_ENDPOINT", nil)
      endpoint = "https://#{endpoint}" if endpoint && !endpoint.start_with?("http://", "https://")
      ak      = global[:'access-key'] || ENV.fetch("AWS_ACCESS_KEY_ID", nil)
      sk      = global[:'secret-key'] || ENV.fetch("AWS_SECRET_ACCESS_KEY", nil)
      endpoint_style = (global[:'endpoint-style'] || ENV.fetch("AWS_ENDPOINT_STYLE", nil))&.to_sym
      signature_version = (global[:'signature-version'] || ENV.fetch("AWS_SIGNATURE_VERSION", nil))&.to_sym || :v4

      if endpoint
        S3MultiBucketClient.new(
          region: region, bucket: bucket, endpoint: endpoint,
          access_key_id: ak, secret_access_key: sk,
          debug: global[:debug],
          signature_version: signature_version,
          **(endpoint_style ? { endpoint_style: endpoint_style } : {})
        )
      else
        S3Client.new(region: region, bucket: bucket,
                     access_key_id: ak, secret_access_key: sk,
                     debug: global[:debug],
                     signature_version: signature_version)
      end
    rescue KeyError => e
      abort "#{C.red_bold('✗')} Missing required credential: #{e.message}"
    end

    # ── Upload ──────────────────────────────────────────────────────

    def cmd_upload(client, args)
      opts = parse_upload_opts(args)
      abort "#{C.red_bold('✗')} Usage: s3sm upload <local_path> --key KEY [--bucket BUCKET]" unless opts[:local_path] && opts[:key]

      path = opts[:local_path]
      key  = opts[:key]
      size = File.exist?(path) ? format_size(File.size(path)) : nil

      $stdout.print "#{C.dim('⬆  Uploading')} #{C.bold(File.basename(path))}"
      $stdout.print " #{C.dim("(#{size})")}" if size
      $stdout.print " #{C.dim('→')} #{C.cyan_bold(key)}"
      $stdout.print " #{C.dim('in')} #{C.magenta_bold(opts[:bucket] || 'default')}" if opts[:bucket]
      $stdout.puts

      result = client.upload_file(**opts)

      puts "  #{C.green_bold('✓')} #{C.green('Uploaded')} #{C.bold(result.key)}"
    end

    def parse_upload_opts(args)
      opts = { local_path: nil, file_path: nil, key: nil, bucket: nil,
               content_type: "application/octet-stream", metadata: {},
               cache_control: nil, skip_existing: false,
               concurrency: nil, retries: nil }
      OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm upload <local_path> [options]"
        o.on("--key KEY", "S3 object key (required)") { |v| opts[:key] = v }
        o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
        o.on("--content-type TYPE", "Content-Type header") { |v| opts[:content_type] = v }
        o.on("--skip-existing", "Skip if object already exists") { opts[:skip_existing] = true }
        o.on("--concurrency N", Integer, "Max concurrent threads") { |v| opts[:concurrency] = v }
        o.on("--retries N", Integer, "Max retries per part") { |v| opts[:retries] = v }
        o.on("--cache-control VAL", "Cache-Control header") { |v| opts[:cache_control] = v }
      end.order!(args)

      path = args.shift
      if path
        opts[:local_path] = path
        opts[:file_path]  = path
      end
      opts[:metadata] = {} if opts[:metadata].nil?
      opts.compact
    end

    # ── Download ────────────────────────────────────────────────────

    def cmd_download(client, args)
      opts = parse_download_opts(args)
      abort "#{C.red_bold('✗')} Usage: s3sm download <key> [local_path] --bucket BUCKET" unless opts[:key]

      $stdout.puts "#{C.dim('⬇  Downloading')} #{C.cyan_bold(opts[:key])} #{C.dim('→')} #{C.bold(opts[:destination_path] || '.')}"
      result = client.download_file(**opts)
      puts "  #{C.green_bold('✓')} #{C.green('Downloaded to')} #{C.bold(result.local_path)}"
    end

    def parse_download_opts(args)
      opts = { key: nil, bucket: nil, destination_path: nil, local_path: nil,
               resume: false }
      OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm download <key> [local_path] [options]"
        o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
        o.on("--resume", "Resume previous download") { opts[:resume] = true }
      end.order!(args)

      opts[:key] = args.shift
      if (dest = args.shift)
        opts[:destination_path] = dest
        opts[:local_path]       = dest
      end
      opts.compact
    end

    # ── Presign ─────────────────────────────────────────────────────

    def cmd_presign(client, args)
      opts = parse_presign_opts(args)
      abort "#{C.red_bold('✗')} Usage: s3sm presign <key> [--bucket BUCKET]" unless opts[:key]

      url = client.presigned_url(**opts)
      puts "#{C.dim('🔗')} #{C.under}#{url}#{C::RESET}"
      puts ""
      puts "#{C.dim('Expires in')} #{C.yellow_bold(opts[:expires_in])} #{C.dim('seconds')}"
    end

    def parse_presign_opts(args)
      opts = { key: nil, bucket: nil, expires_in: 3600, method: :get }
      OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm presign <key> [options]"
        o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
        o.on("--expires SECONDS", Integer, "Expiration in seconds (default: 3600)") { |v| opts[:expires_in] = v }
        o.on("--method METHOD", %w[get put delete head], "HTTP method (get/put/delete/head)") { |v| opts[:method] = v.to_sym }
      end.order!(args)

      opts[:key] = args.shift
      opts.compact
    end

    # ── Delete ──────────────────────────────────────────────────────

    def cmd_delete(client, args)
      opts = parse_delete_opts(args)
      abort "#{C.red_bold('✗')} Usage: s3sm delete <key> [--bucket BUCKET]" unless opts[:key]

      client.delete_object(**opts)
      puts "#{C.red_bold('✗')} #{C.red('Deleted')} #{C.bold(opts[:key])}"
    end

    def parse_delete_opts(args)
      opts = { key: nil, bucket: nil }
      OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm delete <key> [options]"
        o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
      end.order!(args)

      opts[:key] = args.shift
      opts.compact
    end

    # ── List ────────────────────────────────────────────────────────

    def cmd_list(client, args)
      opts = parse_list_opts(args)
      opts[:bucket] ||= client.bucket

      result = client.list_objects(**opts)
      contents = result[:contents]
      common_prefixes = result[:common_prefixes]

      bucket_label = C.magenta_bold(opts[:bucket] || "default")
      prefix_label = opts[:prefix] ? " #{C.dim('(prefix:')} #{C.cyan(opts[:prefix])}#{C.dim(')')}" : ""

      puts ""
      puts "  #{C.bold('📦')} #{C.bold('Objects in')} #{bucket_label}#{prefix_label}"
      puts "  #{C.dim('─' * 78)}"

      if contents.empty? && common_prefixes.empty?
        puts "  #{C.dim('(empty)')}"
        puts ""
        return
      end

      unless contents.empty?
        header = "  #{C.bold(C.white('Key'))}  #{C.bold(C.white('Size'))}  " \
                 "#{C.bold(C.white('Last Modified'))}  #{C.bold(C.white('Class'))}  #{C.bold(C.white('ETag'))}"
        puts header
        puts "  #{C.dim('─' * 78)}"

        contents.each do |obj|
          size_str = obj[:size] ? format_size(obj[:size]) : "—"
          key_display = obj[:key].to_s
          key_display = "#{C.dim('…')}#{key_display[-57..]}" if key_display.length > 60
          key_display = C.green_bold(key_display)

          size_padded = size_str.rjust(10)
          size_display = case obj[:size]
                         when nil..0         then C.dim(size_padded)
                         when 1..(1024**2)   then C.green(size_padded)
                         when (1024**2)..(1024**3) then C.yellow(size_padded)
                         else C.red_bold(size_padded)
                         end

          puts "  #{key_display}  #{size_display}  #{C.dim(obj[:last_modified])}  #{C.cyan(obj[:storage_class])}  #{C.dim(obj[:etag])}"
        end
      end

      if common_prefixes.any?
        puts ""
        puts "  #{C.bold('📁')} #{C.bold('Common prefixes:')}"
        common_prefixes.each { |p| puts "  #{C.blue_bold(p)}" }
      end

      total_size = contents.sum { |o| o[:size] || 0 }
      puts ""
      puts "  #{C.dim('─' * 78)}"
      puts "  #{C.bold('Total:')} #{C.green_bold(contents.size.to_s)} #{contents.size == 1 ? 'object' : 'objects'}, #{C.yellow_bold(format_size(total_size))}"
      puts ""
    end

    def parse_list_opts(args)
      opts = { bucket: nil, prefix: nil, delimiter: "/", max_keys: 100, paginate: true }
      OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm list [options]"
        o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
        o.on("--prefix PREFIX", "Filter by key prefix") { |v| opts[:prefix] = v }
        o.on("--delimiter DELIM", "Delimiter (default: /)") { |v| opts[:delimiter] = v }
        o.on("--max-keys N", Integer, "Max keys to list (default: 1000)") { |v| opts[:max_keys] = v }
        o.on("--no-paginate", "Disable auto-pagination") { opts[:paginate] = false }
      end.order!(args)

      opts.compact
    end

    # ── List Parts ──────────────────────────────────────────────────

    def cmd_list_parts(client, args)
      opts = parse_list_parts_opts(args)
      abort "#{C.red_bold('✗')} Usage: s3sm list-parts <key> --upload-id ID [--bucket BUCKET]" unless opts[:key] && opts[:upload_id]

      result = client.list_parts(**opts)
      parts = result[:parts] || []

      puts ""
      puts "  #{C.bold('🔩')} #{C.bold('Parts for')} #{C.cyan_bold(opts[:key])}"
      puts "  #{C.dim('Upload:')} #{C.yellow(opts[:upload_id])}"
      puts "  #{C.dim('─' * 60)}"

      if parts.empty?
        puts "  #{C.dim('(no parts)')}"
      else
        puts "  #{C.bold(C.white('Part'))}  #{C.bold(C.white('ETag'))}  #{C.bold(C.white('Size'))}"
        puts "  #{C.dim('─' * 60)}"
        parts.each do |p|
          puts "  #{C.magenta_bold("Part #{p[:part_number]}").ljust(12)} #{C.dim(p[:etag])}  #{C.green(format_size(p[:size]))}"
        end
      end
      puts ""
    end

    def parse_list_parts_opts(args)
      opts = { key: nil, upload_id: nil, bucket: nil, max_parts: 100 }
      OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm list-parts <key> --upload-id ID [options]"
        o.on("--upload-id ID", "Upload ID (required)") { |v| opts[:upload_id] = v }
        o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
        o.on("--max-parts N", Integer, "Max parts to list") { |v| opts[:max_parts] = v }
      end.order!(args)

      opts[:key] = args.shift
      opts.compact
    end

    # ── List Uploads ────────────────────────────────────────────────

    def cmd_list_uploads(client, args)
      opts = parse_list_uploads_opts(args)

      result = client.list_multipart_uploads(**opts)
      uploads = result[:uploads] || []

      prefix_label = opts[:prefix] ? " #{C.dim('(prefix:')} #{C.cyan(opts[:prefix])}#{C.dim(')')}" : ""

      puts ""
      puts "  #{C.bold('📋')} #{C.bold('Multipart uploads')}#{prefix_label}"
      puts "  #{C.dim('─' * 70)}"

      if uploads.empty?
        puts "  #{C.dim('(none)')}"
      else
        puts "  #{C.bold(C.white('Key'))}  #{C.bold(C.white('Upload ID'))}  #{C.bold(C.white('Initiated'))}"
        puts "  #{C.dim('─' * 70)}"
        uploads.each do |u|
          puts "  #{C.green_bold(u[:key])}  #{C.yellow(u[:upload_id])}  #{C.dim(u[:initiated])}"
        end
      end
      puts ""
    end

    def parse_list_uploads_opts(args)
      opts = { bucket: nil, prefix: nil, max_uploads: 100 }
      OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm list-uploads [options]"
        o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
        o.on("--prefix PREFIX", "Filter by key prefix") { |v| opts[:prefix] = v }
        o.on("--max-uploads N", Integer, "Max uploads to list") { |v| opts[:max_uploads] = v }
      end.order!(args)

      opts.compact
    end

    # ── Upload Dir ──────────────────────────────────────────────────

    def cmd_upload_dir(client, args)
      opts = parse_upload_dir_opts(args)
      abort "#{C.red_bold('✗')} Usage: s3sm upload-dir <directory> [--bucket BUCKET]" unless opts[:directory]

      $stdout.puts "#{C.dim('📂 Uploading directory')} #{C.bold(opts[:directory])} #{C.dim('→')} #{C.magenta_bold(opts[:bucket] || 'default')}"
      result = client.upload_directory(**opts)
      puts "  #{C.green_bold('✓')} #{C.green('Uploaded')} #{C.green_bold(result.size.to_s)} " \
           "#{result.size == 1 ? 'file' : 'files'} from #{C.bold(opts[:directory])}"
    end

    def parse_upload_dir_opts(args)
      opts = { directory: nil, bucket: nil, prefix: "", pattern: "**/*",
               exclude: [], max_files: 4, skip_existing: false }
      OptionParser.new do |o|
        o.banner = "#{C.bold('Usage:')} s3sm upload-dir <directory> [options]"
        o.on("--bucket BUCKET", "Bucket name (overrides global)") { |v| opts[:bucket] = v }
        o.on("--prefix PREFIX", "Key prefix for uploaded files") { |v| opts[:prefix] = v }
        o.on("--pattern PAT", "File glob pattern (default: **/*)") { |v| opts[:pattern] = v }
        o.on("--max-files N", Integer, "Max concurrent file uploads") { |v| opts[:max_files] = v }
        o.on("--skip-existing", "Skip objects that already exist") { opts[:skip_existing] = true }
      end.order!(args)

      opts[:directory] = args.shift
      opts.compact
    end

